EXPO_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=TU_ANON_KEY

# ---- Gemini AI ----
# Obtenla en: https://aistudio.google.com/apikey
EXPO_PUBLIC_GEMINI_API_KEY=TU_GEMINI_API_KEY
